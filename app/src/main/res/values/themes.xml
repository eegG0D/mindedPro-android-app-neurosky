<?xml version="1.0" encoding="utf-8"?>
<resources>
    <!--
        A thin pre-Compose theme. All real styling is done by MindedProTheme in
        Compose; this only paints the launch window so there is no white flash.
    -->
    <style name="Theme.MindedPro" parent="android:Theme.Material.NoActionBar">
        <item name="android:windowBackground">@color/minded_background</item>
        <item name="android:statusBarColor">@color/minded_background</item>
        <item name="android:navigationBarColor">@color/minded_background</item>
        <item name="android:windowLightStatusBar">false</item>
    </style>
</resources>
